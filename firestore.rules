rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Default safety net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Shared global primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        request.auth.token.email_verified == true && 
        (request.auth.token.email == 'aki.sokpah.link@gmail.com' || request.auth.token.email == 'luckyglobalnews@gmail.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Bulletin Rules (Public read, admin write)
    match /bulletins/{bulletinId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(bulletinId) && isValidBulletin(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(bulletinId) && isValidBulletin(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    function isValidBulletin(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             data.author is string && data.author.size() > 0 && data.author.size() <= 100;
    }

    // 3. Student Profile Rules (Authenticated read, admin write)
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(studentId) && isValidStudent(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(studentId) && isValidStudent(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    function isValidStudent(data) {
      return data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.password is string && data.password.size() > 0 && data.password.size() <= 100 &&
             data.gradeLevel is string && data.gradeLevel.size() > 0 && data.gradeLevel.size() <= 50;
    }

    // 4. Report Rules (Authenticated read/query, admin write)
    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(reportId) && isValidReport(incoming()) && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(reportId) && isValidReport(incoming()) && incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    function isValidReport(data) {
      return data.studentId is string && data.studentId.size() > 0 && data.studentId.size() <= 100 &&
             data.term is string && data.term.size() > 0 && data.term.size() <= 100 &&
             data.academicYear is string && data.academicYear.size() > 0 && data.academicYear.size() <= 50 &&
             data.average is number && data.average >= 0 && data.average <= 100 &&
             data.gpa is number && data.gpa >= 0.0 && data.gpa <= 4.0 &&
             data.status is string && (data.status == 'Pass' || data.status == 'Fail');
    }
  }
}
