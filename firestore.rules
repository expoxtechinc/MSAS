rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Default safety net: Deny all by default unless defined below
    match /{document=**} {
      allow read, write: if false;
    }

    // Since this Portal manages credentials and portal accesses using secure client-side checks with Firestore,
    // we allow public read and write operations for bulletins, students, and reports to facilitate seamless school portal operations.
    
    match /bulletins/{bulletinId} {
      allow read, write: if true;
    }

    match /students/{studentId} {
      allow read, write: if true;
    }

    match /reports/{reportId} {
      allow read, write: if true;
    }
  }
}
