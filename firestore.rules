rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default safety net: Deny all by default unless defined below
    match /{document=**} {
      allow read, write: if false;
    }

    // Portal Collections - Public read and write operations are permitted 
    // to facilitate seamless administrative and student portal operations.
    
    match /bulletins/{bulletinId} {
      allow read, write: if true;
    }

    match /students/{studentId} {
      allow read, write: if true;
    }

    match /reports/{reportId} {
      allow read, write: if true;
    }

    match /inquiries/{inquiryId} {
      allow read, write: if true;
    }

    match /emails/{emailId} {
      allow read, write: if true;
    }
  }
}
