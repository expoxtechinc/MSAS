{
  "entities": {
    "students": {
      "title": "Student",
      "description": "Student record for individual portal access.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Unique Alphanumeric Student ID used for login." },
        "name": { "type": "string", "description": "Full name of the student." },
        "password": { "type": "string", "description": "Password used for login." },
        "gradeLevel": { "type": "string", "description": "Grade level / Class (e.g., Grade 9, Grade 12)." },
        "gender": { "type": "string", "description": "Gender of the student." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["studentId", "name", "password", "gradeLevel"]
    },
    "reports": {
      "title": "Academic Report",
      "description": "Student report card and grades.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Alphanumeric Student ID." },
        "studentName": { "type": "string", "description": "Student cached full name." },
        "gradeLevel": { "type": "string", "description": "Grade level when report was issued." },
        "term": { "type": "string", "description": "Academic term (e.g. Ist Period, IInd Period, Final)." },
        "academicYear": { "type": "string", "description": "Academic calendar year (e.g. 2025-2026)." },
        "grades": {
          "type": "array",
          "description": "List of subject grades."
        },
        "average": { "type": "number", "description": "Average numeric grade (0-100)." },
        "gpa": { "type": "number", "description": "Calculated GPA based on standard grade points." },
        "status": { "type": "string", "description": "Status: Pass or Fail (Fail if average < 74)." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last updated timestamp." }
      },
      "required": ["studentId", "term", "academicYear", "grades", "average", "gpa", "status"]
    },
    "bulletins": {
      "title": "Official Announcement",
      "description": "Announcements, news, and posts on the official school platform.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the post." },
        "content": { "type": "string", "description": "Content of the announcement in markdown." },
        "category": { "type": "string", "description": "Category e.g. Notice, Event, Academics." },
        "author": { "type": "string", "description": "Author name." },
        "imageUrl": { "type": "string", "description": "Optional attachment cover image URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Post timestamp." }
      },
      "required": ["title", "content", "category", "author", "createdAt"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "students",
      "description": "Collection of student portal credentials and basic info."
    },
    "/reports/{reportId}": {
      "schema": "reports",
      "description": "Collection of student academic report cards."
    },
    "/bulletins/{bulletinId}": {
      "schema": "bulletins",
      "description": "Official announcements visible on the homepage."
    }
  }
}
